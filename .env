# Application Settings
APP_NAME="ServiceMarketplace"
APP_URL="http://localhost/service-marketplace-saas"
APP_VERSION="1.0.0"

# Database Settings (PostgreSQL)
DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="service_saas_db"
DB_USER="postgres"
DB_PASS="your_password_here"

# Security
JWT_SECRET="your_random_secret_key_here"
HASH_SALT="your_random_salt_here"

# Notification Settings
OTP_EXPIRY=300 # 5 minutes in seconds
